{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
           "src": "../BOOSEapp/BOOSEapp",
           "files": ["*.csproj"]
          },
	  {
	   "src": "../BOOSEapp/BOOSEappTests",
	   "files": ["*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "BOOSEapp Documentation",
      "_appTitle": "BOOSEapp Documentation",
      "_enableSearch": true,
      "pdf": false
    }
  }
}